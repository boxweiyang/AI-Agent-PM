# 若 `npm install` 长时间停在转圈、无日志：多半是访问官方 registry 超时（网络/地区原因）。
# 本文件仅作用于 PMP_Web 目录；也可全局执行：
#   npm config set registry https://registry.npmmirror.com
registry=https://registry.npmmirror.com

# 拉大包（如 msw）时适当放宽，避免误判为「卡死」
fetch-retries=5
fetch-retry-mintimeout=20000
fetch-retry-maxtimeout=120000

# --- HTTPS 证书（UNABLE_TO_GET_ISSUER_CERT_LOCALLY）---
# 常见原因：公司 SSL 解密代理 / 杀毒扫描 HTTPS / 本机缺少中间证书。
# 推荐：向 IT 索取「根证书 .pem」，每次装依赖前执行（路径换成你的文件）：
#   export NODE_EXTRA_CA_CERTS=/path/to/corp-root.pem
# 或写入 ~/.zshrc 仅本机生效。
# 临时绕过校验（仅本机、勿提交）：取消下一行注释，或执行 npm config set strict-ssl false
# strict-ssl=false
