# 默认留空：开发时使用 vite proxy，请求同源 /api → PMP_Service
# 若需浏览器直连后端，可设为：VITE_API_BASE=http://127.0.0.1:8000
# VITE_API_BASE=

# 是否启用 MSW Mock（与 .env.development 一致即可；仅 DEV 生效）
# true = 拦截 /api/v1/* 等已声明路由，无需后端
# false = 请求走 Vite proxy 到真实 PMP_Service
# VITE_USE_MSW=true
#
# 也可不改本文件，直接用 npm 脚本（cross-env）：
#   npm run dev:mock   → 强制 Mock
#   npm run dev:api    → 强制连真实后端
